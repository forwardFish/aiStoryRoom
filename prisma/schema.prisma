generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  openid                String    @unique
  unionid               String?
  email                 String?   @unique
  passwordHash          String?
  emailVerifiedAt       DateTime?
  verificationTokenHash String?
  nickname              String?
  avatarUrl             String?
  status                String    @default("active")
  policyAgreedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  ownedRuns     StoryRun[]     @relation("StoryRunOwner")
  players       StoryPlayer[]
  actions       PlayerAction[]
  notifications Notification[]
  eventLogs     EventLog[]
  shareTokens   ShareToken[]
  authTokens    AuthOneTimeToken[]
  authIdentities AuthIdentity[]
  refundRequests RefundRequest[] @relation("RefundRequester")
  reviewedRefundRequests RefundRequest[] @relation("RefundReviewer")
  roleControlTransitions RoleControlTransition[] @relation("RoleControlTransitionInitiator")
  eventDeliveries        EventDelivery[]
  eventDeliveryCursors   EventDeliveryCursor[]
  presenceSessions       PresenceSession[]

  @@index([status])
  @@index([createdAt])
}

enum AuthTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum AuthProvider {
  GOOGLE
}

model AuthOneTimeToken {
  id                 String           @id @default(cuid())
  userId             String
  purpose            AuthTokenPurpose
  tokenHash          String           @unique
  expiresAt          DateTime
  consumedAt         DateTime?
  invalidatedAt      DateTime?
  failedAttempts     Int              @default(0)
  sentAt             DateTime?
  deliveryProvider   String?
  deliveryProviderId String?
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}

model AuthIdentity {
  id                      String       @id @default(cuid())
  userId                  String
  provider                AuthProvider
  providerSubject         String
  providerEmail           String?
  providerEmailVerifiedAt DateTime?
  hostedDomain            String?
  profileJson             Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([provider, providerEmail])
}

model AuthLoginChallenge {
  id         String       @id @default(cuid())
  provider   AuthProvider
  nonceHash  String       @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([provider, expiresAt, consumedAt])
}

model WorldTemplate {
  id         String   @id
  name       String
  genre      String
  hook       String   @db.Text
  worldBase  String   @db.Text
  status     String   @default("draft")
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  storyRuns StoryRun[]

  @@index([status])
  @@index([genre])
}

model StoryRun {
  id                 String         @id @default(cuid())
  templateId         String
  ownerUserId        String
  title              String
  hook               String         @db.Text
  mode               String         @default("invite")
  templateKey        String         @default("sangtian")
  userId             String?
  selectedRoleKey    String?
  status             String         @default("waiting_players")
  currentDay         Int            @default(1)
  totalDays          Int            @default(7)
  version            Int            @default(1)
  currentChapter     Int            @default(1)
  currentNodeId      String?
  maxPlayers         Int            @default(5)
  activeHumanCount   Int            @default(1)
  aiPlayerCount      Int            @default(0)
  dangerLevel        Int            @default(1)
  maxDangerLevel     Int            @default(5)
  chapterCount       Int            @default(0)
  completedNodeCount Int            @default(0)
  summary            String?        @db.Text
  stateJson          Json
  visibility         String         @default("link")
  inviteCode         String         @unique
  accessLevel        RunAccessLevel @default(FREE_TRIAL)
  freeDecisionsUsed  Int            @default(0)
  paywallReachedAt   DateTime?
  unlockedAt         DateTime?
  engineVersion      String         @default("legacy_v1")
  strategyVersion    String         @default("legacy_v1")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  template          WorldTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  owner             User                 @relation("StoryRunOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  players           StoryPlayer[]
  roles             StoryRole[]
  relations         RoleRelation[]
  sandboxes         ChapterSandbox[]
  nodes             SceneNode[]
  actions           PlayerAction[]
  resolutions       DirectorResolution[]
  narrativeSegments NarrativeSegment[]
  clues             Clue[]
  snapshots         WorldStateSnapshot[]
  chapters          Chapter[]
  notifications     Notification[]
  aiTasks           AiTask[]
  outboxTasks       StoryTaskOutbox[]
  events            EventLog[]
  storyEvents       StoryEvent[]         @relation("StoryRunStoryEvents")
  shareTokens       ShareToken[]
  worldUnlock       WorldUnlock?
  canonFacts        CanonFact[]
  characterMinds    CharacterMind[]
  storyThreads      StoryThread[]
  sceneSnapshots    SceneSnapshot[]
  narrativeEntries  NarrativeEntry[]
  actionWindows      ActionWindow[]
  roleControls       RoleControl[]
  interactionRequests InteractionRequest[]
  roleAssets         RoleAsset[]
  storyEventCursor   StoryEventCursor?
  eventDeliveries    EventDelivery[]
  eventDeliveryCursors EventDeliveryCursor[]
  presenceSessions     PresenceSession[]
  roleAgentPolicies  RoleAgentPolicy[]
  roleAgentProjections RoleAgentProjection[]
  roleAgentDecisions RoleAgentDecision[]
  resolutionWorkflows ResolutionWorkflow[]

  @@index([templateId])
  @@index([ownerUserId])
  @@index([status, updatedAt])
  @@index([visibility, status])
  @@index([templateKey, status])
}

enum RunAccessLevel {
  FREE_TRIAL
  UNLOCKED
}

model StoryEvent {
  id                      String   @id
  runId                   String
  day                     Int
  type                    String
  messageType             String   @default("system")
  roleKey                 String?
  visibility              String   @default("player_visible")
  payloadJson             Json
  sequence                Int?
  dedupeKey               String?  @unique
  audienceType            String?
  audienceRoleIdsJson     Json?
  sourceActionId          String?
  createdAt               DateTime @default(now())

  run          StoryRun       @relation("StoryRunStoryEvents", fields: [runId], references: [id], onDelete: Cascade)
  sourceAction PlayerAction?  @relation("StoryEventSourceAction", fields: [sourceActionId], references: [id], onDelete: SetNull)
  deliveries   EventDelivery[]

  @@unique([runId, sequence])
  @@index([runId, day, createdAt])
  @@index([runId, type])
  @@index([sourceActionId])
}

model StoryPlayer {
  id           String    @id @default(cuid())
  runId        String
  userId       String?
  roleId       String?
  playerType   String    @default("human")
  status       String    @default("active")
  joinedAt     DateTime  @default(now())
  lastActiveAt DateTime?

  run  StoryRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  role StoryRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  roleControls RoleControl[]
  presenceSessions PresenceSession[]

  @@unique([runId, userId])
  @@unique([runId, roleId])
  @@index([runId, status])
  @@index([userId])
}

model StoryRole {
  id             String   @id @default(cuid())
  runId          String
  roleKey        String
  roleName       String
  identity       String
  publicInfo     String   @db.Text
  hiddenSecret   String?  @db.Text
  personalGoal   String   @db.Text
  currentState   String   @db.Text
  abilityText    String?  @db.Text
  arcText        String?  @db.Text
  knownInfoJson  Json
  cannotDoJson   Json
  isAiControlled Boolean  @default(false)
  status         String   @default("available")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  run              StoryRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  players          StoryPlayer[]
  actions          PlayerAction[]
  ownedClues       Clue[]
  fromRelations    RoleRelation[]   @relation("RelationFromRole")
  toRelations      RoleRelation[]   @relation("RelationToRole")
  characterMind    CharacterMind?
  sceneSnapshots   SceneSnapshot[]
  narrativeEntries NarrativeEntry[]
  targetedActions   PlayerAction[]                  @relation("PlayerActionTargetRole")
  openingProjections ActionWindowOpeningProjection[]
  windowParticipants ActionWindowParticipant[]
  roleControls       RoleControl[]
  targetedInteractionRequests InteractionRequest[]  @relation("InteractionTargetRole")
  ownedRoleAssets    RoleAsset[]                     @relation("RoleAssetOwner")
  assetMutationsFrom RoleAssetMutation[]             @relation("RoleAssetMutationFromRole")
  assetMutationsTo   RoleAssetMutation[]             @relation("RoleAssetMutationToRole")
  eventDeliveries    EventDelivery[]
  roleAgentPolicies  RoleAgentPolicy[]
  roleAgentProjections RoleAgentProjection[]
  roleAgentDecisions RoleAgentDecision[]
  targetedRoleAgentDecisions RoleAgentDecision[] @relation("RoleAgentDecisionTargetRole")
  presenceSessions PresenceSession[]
  outboxTasks        StoryTaskOutbox[]

  @@unique([runId, roleKey])
  @@index([runId, status])
  @@index([isAiControlled])
}

model RoleRelation {
  id              String   @id @default(cuid())
  runId           String
  fromRoleId      String
  toRoleId        String
  relationType    String
  score           Int      @default(0)
  publicNote      String?  @db.Text
  hiddenNote      String?  @db.Text
  updatedByNodeId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run      StoryRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  fromRole StoryRole @relation("RelationFromRole", fields: [fromRoleId], references: [id], onDelete: Cascade)
  toRole   StoryRole @relation("RelationToRole", fields: [toRoleId], references: [id], onDelete: Cascade)

  @@unique([runId, fromRoleId, toRoleId, relationType])
  @@index([runId])
  @@index([fromRoleId])
  @@index([toRoleId])
}

model ChapterSandbox {
  id              String   @id @default(cuid())
  runId           String
  chapterIndex    Int
  title           String
  mainLocation    String
  chapterGoal     String   @db.Text
  currentQuestion String   @db.Text
  sandboxJson     Json
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run StoryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, chapterIndex])
  @@index([runId, status])
}

model SceneNode {
  id                String    @id @default(cuid())
  runId             String
  chapterIndex      Int
  nodeIndex         Int
  title             String
  publicNarration   String    @db.Text
  nodeGoal          String    @db.Text
  status            String    @default("open_for_actions")
  actionOptionsJson Json
  resolutionId      String?
  openedAt          DateTime  @default(now())
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  run               StoryRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  actions           PlayerAction[]
  resolution        DirectorResolution?
  narrativeSegments NarrativeSegment[]
  snapshots         WorldStateSnapshot[]
  aiTasks           AiTask[]
  outboxTasks       StoryTaskOutbox[]
  events            EventLog[]
  notifications     Notification[]
  canonFacts        CanonFact[]          @relation("CanonFactSourceNode")
  sceneSnapshots    SceneSnapshot[]
  narrativeEntries  NarrativeEntry[]
  actionWindow      ActionWindow?
  interactionRequests InteractionRequest[]
  resolutionWorkflow ResolutionWorkflow?

  @@unique([runId, chapterIndex, nodeIndex])
  @@index([runId, status])
  @@index([chapterIndex])
}

model PlayerAction {
  id                         String   @id @default(cuid())
  runId                      String
  nodeId                     String
  chapterIndex               Int
  userId                     String?
  roleId                     String?
  playerType                 String   @default("human")
  actionType                 String
  targetType                 String?
  targetId                   String?
  targetText                 String?
  method                     String   @db.Text
  intent                     String   @db.Text
  riskLevel                  String   @default("normal")
  freeText                   String?  @db.Text
  normalizedJson             Json?
  guardStatus                String   @default("pending")
  guardReason                String?  @db.Text
  auditStatus                String   @default("pending")
  status                     String   @default("draft")
  actionSlot                 String?  @default("MAIN")
  actorKind                  String?
  controlEpoch               Int?     @default(0)
  policyVersion              String?
  provider                   String?
  modelName                  String?
  actionKey                  String?
  idempotencyKey             String?  @unique
  requestHash                String?
  sourceInteractionRequestId String?  @unique
  visibility                 String?
  targetRoleId               String?
  leverageKey                String?
  sealedAt                   DateTime?
  expiresAt                  DateTime?
  immediateJson              Json?
  resolvedJson               Json?
  resolvedAt                 DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  run                       StoryRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  node                      SceneNode           @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user                      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  role                      StoryRole?          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  targetRole                StoryRole?          @relation("PlayerActionTargetRole", fields: [targetRoleId], references: [id], onDelete: SetNull)
  sourceInteractionRequest  InteractionRequest? @relation("PlayerActionSourceInteraction", fields: [sourceInteractionRequestId], references: [id], onDelete: SetNull)
  initiatedInteractions     InteractionRequest[] @relation("InteractionSourceAction")
  recordedInteractionResponse InteractionRequest? @relation("InteractionResponseActionId")
  sourceEvents              StoryEvent[]        @relation("StoryEventSourceAction")
  assetMutations            RoleAssetMutation[]
  roleAgentDecision         RoleAgentDecision?
  aiTasks                   AiTask[]
  events                    EventLog[]

  @@unique([nodeId, roleId, actionSlot])
  @@index([runId, nodeId])
  @@index([userId])
  @@index([targetRoleId])
  @@index([status, auditStatus, guardStatus])
}

model ActionWindow {
  id                     String   @id @default(cuid())
  runId                  String
  nodeId                 String   @unique
  status                 String   @default("PREPARING")
  mainOpenedAt           DateTime?
  mainClosesAt           DateTime?
  graceOpenedAt          DateTime?
  graceMinClosesAt       DateTime?
  graceClosesAt          DateTime?
  aiQueueDrainedAt       DateTime?
  closingReason          String?
  resolutionTaskId       String?  @unique
  openingSnapshotVersion Int?
  projectionVersion      Int      @default(0)
  version                Int      @default(1)
  resolvedAt             DateTime?
  configJson             Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  run                    StoryRun                       @relation(fields: [runId], references: [id], onDelete: Cascade)
  node                   SceneNode                      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  resolutionTask         StoryTaskOutbox?               @relation("ActionWindowResolutionTask", fields: [resolutionTaskId], references: [id], onDelete: SetNull)
  openingProjections     ActionWindowOpeningProjection[]
  participants           ActionWindowParticipant[]
  reclaimingRoleControls RoleControl[]                  @relation("RoleControlReclaimAfterWindow")
  stageLeavingRoleControls RoleControl[]                @relation("RoleControlStageLeaveWindow")
  effectiveTransitions   RoleControlTransition[]
  interactionRequests    InteractionRequest[]
  outboxTasks            StoryTaskOutbox[]               @relation("StoryTaskOutboxWindow")
  roleAgentProjections   RoleAgentProjection[]
  roleAgentDecisions     RoleAgentDecision[]
  resolutionWorkflow     ResolutionWorkflow?

  @@index([status, mainClosesAt])
  @@index([status, graceClosesAt])
  @@index([runId, status])
}

model ActionWindowOpeningProjection {
  id              String   @id @default(cuid())
  windowId        String
  roleId          String
  snapshotVersion Int
  projectionJson  Json
  contentHash     String
  createdAt       DateTime @default(now())

  window ActionWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  role   StoryRole    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([windowId, roleId])
  @@index([windowId, snapshotVersion])
}

model ActionWindowParticipant {
  id             String    @id @default(cuid())
  windowId       String
  roleId         String
  mainStatus     String    @default("PENDING")
  maneuverStatus String    @default("LOCKED")
  reactionStatus String    @default("NOT_OPEN")
  maneuverUsedAt DateTime?
  reactionUsedAt DateTime?
  doneAt         DateTime?
  version        Int       @default(1)

  window ActionWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  role   StoryRole    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([windowId, roleId])
  @@index([windowId, mainStatus, doneAt])
}

model RoleControl {
  id                   String   @id @default(cuid())
  runId                String
  roleId               String
  humanPlayerId        String?
  mode                 String
  epoch                Int      @default(1)
  reason               String?
  lastHeartbeatAt      DateTime?
  offlineSince         DateTime?
  takeoverAt           DateTime?
  reclaimAfterWindowId String?
  stageLeaveWindowId   String?
  policyVersion        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  run                StoryRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  role               StoryRole    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  humanPlayer        StoryPlayer? @relation(fields: [humanPlayerId], references: [id], onDelete: SetNull)
  reclaimAfterWindow ActionWindow? @relation("RoleControlReclaimAfterWindow", fields: [reclaimAfterWindowId], references: [id], onDelete: SetNull)
  stageLeaveWindow   ActionWindow? @relation("RoleControlStageLeaveWindow", fields: [stageLeaveWindowId], references: [id], onDelete: SetNull)
  transitions       RoleControlTransition[]

  @@unique([runId, roleId])
  @@index([mode, lastHeartbeatAt])
  @@index([humanPlayerId])
}

model RoleControlTransition {
  id                String   @id @default(cuid())
  roleControlId     String
  fromMode          String
  toMode            String
  fromEpoch         Int
  toEpoch           Int
  reason            String
  initiatedByUserId String?
  effectiveWindowId String?
  effectiveSlot     String?
  idempotencyKey    String   @unique
  createdAt         DateTime @default(now())

  roleControl    RoleControl @relation(fields: [roleControlId], references: [id], onDelete: Cascade)
  initiatedByUser User?      @relation("RoleControlTransitionInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  effectiveWindow ActionWindow? @relation(fields: [effectiveWindowId], references: [id], onDelete: SetNull)

  @@index([roleControlId, createdAt])
  @@index([effectiveWindowId])
}

model PresenceSession {
  id                          String   @id @default(cuid())
  runId                       String
  userId                      String
  playerId                    String
  roleId                      String
  sessionInstanceId           String
  lastHeartbeatSequence       Int      @default(0)
  lastAppliedDeliverySequence Int      @default(0)
  lastHeartbeatAt             DateTime @default(now())
  expiresAt                   DateTime
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  run    StoryRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  player StoryPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  role   StoryRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([runId, userId, sessionInstanceId])
  @@index([runId, lastHeartbeatAt])
  @@index([playerId, expiresAt])
  @@index([roleId, lastHeartbeatAt])
}

model InteractionRequest {
  id                 String   @id @default(cuid())
  runId              String
  nodeId              String
  windowId            String
  sourceActionId      String
  targetRoleId        String
  eventType           String
  priority            Int      @default(0)
  status              String   @default("OPEN")
  opensAt             DateTime @default(now())
  expiresAt           DateTime
  defaultOutcomeJson  Json
  responseActionId    String?  @unique
  dedupeKey           String   @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  run              StoryRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  node             SceneNode   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  window           ActionWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  sourceAction     PlayerAction @relation("InteractionSourceAction", fields: [sourceActionId], references: [id], onDelete: Restrict)
  targetRole       StoryRole    @relation("InteractionTargetRole", fields: [targetRoleId], references: [id], onDelete: Restrict)
  responseAction   PlayerAction? @relation("InteractionResponseActionId", fields: [responseActionId], references: [id], onDelete: SetNull)
  consumedResponse PlayerAction? @relation("PlayerActionSourceInteraction")

  @@index([runId, status])
  @@index([windowId, targetRoleId, status])
  @@index([sourceActionId])
}

model RoleAsset {
  id          String   @id @default(cuid())
  runId       String
  assetKey    String
  kind        String
  ownerRoleId String?
  ownerActorKey String?
  quantity    Int      @default(0)
  status      String   @default("ACTIVE")
  visibility  String   @default("PRIVATE")
  stateJson   Json
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  run       StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  ownerRole StoryRole?         @relation("RoleAssetOwner", fields: [ownerRoleId], references: [id], onDelete: Restrict)
  mutations RoleAssetMutation[]

  @@unique([runId, assetKey])
  @@index([ownerRoleId, status])
  @@index([ownerActorKey, status])
}

model RoleAssetMutation {
  id             String   @id @default(cuid())
  assetId        String
  actionId       String
  mutationType   String
  delta          Int
  fromRoleId     String?
  toRoleId       String?
  beforeJson     Json
  afterJson      Json
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  asset   RoleAsset   @relation(fields: [assetId], references: [id], onDelete: Restrict)
  action  PlayerAction @relation(fields: [actionId], references: [id], onDelete: Restrict)
  fromRole StoryRole? @relation("RoleAssetMutationFromRole", fields: [fromRoleId], references: [id], onDelete: SetNull)
  toRole   StoryRole? @relation("RoleAssetMutationToRole", fields: [toRoleId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@index([actionId])
}

model StoryEventCursor {
  id           String   @id @default(cuid())
  runId        String   @unique
  nextSequence Int      @default(1)
  version      Int      @default(1)
  updatedAt    DateTime @updatedAt

  run StoryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model EventDeliveryCursor {
  id           String   @id @default(cuid())
  roomId       String
  userId       String
  nextSequence Int      @default(1)
  version      Int      @default(1)
  updatedAt    DateTime @updatedAt

  room StoryRun @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model EventDelivery {
  id               String   @id @default(cuid())
  eventId          String
  roomId           String
  userId           String
  roleId           String?
  deliverySequence Int
  payloadJson      Json
  deliveredAt      DateTime @default(now())

  event StoryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room  StoryRun   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  StoryRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([roomId, userId, deliverySequence])
  @@unique([eventId, userId])
  @@index([userId, deliveredAt])
  @@index([roleId])
}

model RoleAgentPolicy {
  id                 String   @id @default(cuid())
  runId              String
  roleId             String
  policyVersion      String
  promptVersion      String
  provider           String
  modelName          String
  goalsJson          Json
  riskProfileJson    Json
  assetPriorityJson  Json
  actionWeightsJson  Json
  fallbackBySlotJson Json
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  supersededAt       DateTime?

  run  StoryRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  role StoryRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([runId, roleId, policyVersion])
  @@index([runId, roleId, status])
}

model RoleAgentProjection {
  id                     String   @id @default(cuid())
  runId                  String
  windowId               String
  roleId                 String
  actionSlot             String
  controlEpoch           Int
  policyVersion          String
  openingSnapshotVersion Int
  projectionJson         Json
  contentHash            String
  createdAt              DateTime @default(now())

  run       StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  window    ActionWindow       @relation(fields: [windowId], references: [id], onDelete: Cascade)
  role      StoryRole          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  decisions RoleAgentDecision[]

  @@unique([windowId, roleId, actionSlot, controlEpoch])
  @@index([runId, roleId, createdAt])
}

model RoleAgentDecision {
  id                     String   @id @default(cuid())
  runId                  String
  windowId               String
  roleId                 String
  actionSlot             String
  controlEpoch           Int
  policyVersion          String
  openingSnapshotVersion Int
  taskDedupeKey          String   @unique
  projectionId           String
  status                 String   @default("PENDING")
  visibleFactIdsJson     Json
  chosenActionKey        String?
  targetRoleId           String?
  leverageKey            String?
  shortRationale         String?
  provider               String?
  modelName              String?
  providerAttempts       Int      @default(0)
  providerResponseHash   String?
  guardDecisionJson      Json?
  playerActionId         String?  @unique
  lastError              String?  @db.Text
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  run          StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  window       ActionWindow       @relation(fields: [windowId], references: [id], onDelete: Cascade)
  role         StoryRole          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  targetRole   StoryRole?         @relation("RoleAgentDecisionTargetRole", fields: [targetRoleId], references: [id], onDelete: SetNull)
  projection   RoleAgentProjection @relation(fields: [projectionId], references: [id], onDelete: Cascade)
  playerAction PlayerAction?      @relation(fields: [playerActionId], references: [id], onDelete: SetNull)

  @@unique([windowId, roleId, actionSlot, controlEpoch])
  @@index([runId, roleId, createdAt])
  @@index([projectionId])
}

model ResolutionWorkflow {
  id              String   @id @default(cuid())
  runId           String
  windowId        String   @unique
  nodeId          String   @unique
  resolutionId    String?  @unique
  status          String   @default("RUNNING")
  rulesInputHash  String
  rulesOutputJson Json?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  run         StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  window      ActionWindow       @relation(fields: [windowId], references: [id], onDelete: Cascade)
  node        SceneNode          @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  resolution  DirectorResolution? @relation(fields: [resolutionId], references: [id], onDelete: SetNull)
  checkpoints ResolutionCheckpoint[]

  @@index([runId, status])
}

model ResolutionCheckpoint {
  id            String   @id @default(cuid())
  workflowId    String
  checkpointKey String
  contentHash   String
  outputRefType String?
  outputRefId   String?
  completedAt   DateTime @default(now())

  workflow ResolutionWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, checkpointKey])
}

model DirectorResolution {
  id                  String   @id @default(cuid())
  runId               String
  nodeId              String   @unique
  chapterIndex        Int
  summary             String   @db.Text
  publicNarration     String   @db.Text
  privateResultsJson  Json
  actionResultsJson   Json
  statePatchJson      Json
  clueChangesJson     Json
  relationChangesJson Json
  dangerBefore        Int
  dangerAfter         Int
  nextNodeHook        String?  @db.Text
  nextOptionsJson     Json?
  auditStatus         String   @default("ok")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  run               StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  node              SceneNode          @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  narrativeSegments NarrativeSegment[]
  narrativeEntries  NarrativeEntry[]
  resolutionWorkflow ResolutionWorkflow?

  @@index([runId, chapterIndex])
  @@index([auditStatus])
}

model NarrativeSegment {
  id              String   @id @default(cuid())
  runId           String
  nodeId          String
  resolutionId    String
  chapterIndex    Int
  content         String   @db.Text
  contributorJson Json
  auditStatus     String   @default("ok")
  createdAt       DateTime @default(now())

  run        StoryRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  node       SceneNode          @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  resolution DirectorResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)

  @@index([runId, chapterIndex])
  @@index([nodeId])
  @@index([auditStatus])
}

/// Append-only canonical facts are the authoritative causal memory of a run.
/// A fact is either confirmed public state or a role-scoped belief; the
/// visibility field is always consulted before material is projected to users.
model CanonFact {
  id                  String   @id @default(cuid())
  runId               String
  sourceNodeId        String?
  factKey             String
  content             String   @db.Text
  status              String   @default("confirmed")
  visibility          String   @default("public")
  sourceEventIdsJson  Json
  sourceActionIdsJson Json
  knownByRoleIdsJson  Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  run        StoryRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceNode SceneNode? @relation("CanonFactSourceNode", fields: [sourceNodeId], references: [id], onDelete: SetNull)

  @@unique([runId, factKey])
  @@index([runId, visibility, status])
  @@index([sourceNodeId])
}

/// Per-role epistemic state.  confirmedFactKeys and believedFactKeys are kept
/// separate so an inference never becomes a confirmed public fact by accident.
model CharacterMind {
  id                    String   @id @default(cuid())
  runId                 String
  roleId                String   @unique
  confirmedFactKeysJson Json
  believedFactKeysJson  Json
  activeGoalsJson       Json
  knowledgeBoundaryJson Json
  lastNodeId            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  run  StoryRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  role StoryRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([runId, updatedAt])
  @@index([roleId])
}

/// A tracked pressure line that must be progressed, resolved, or explicitly
/// deferred on each relevant node.
model StoryThread {
  id                 String   @id @default(cuid())
  runId              String
  threadKey          String
  title              String
  status             String   @default("active")
  tension            Int      @default(1)
  deadlineNodeIndex  Int?
  sourceFactKeysJson Json
  stateJson          Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  run StoryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, threadKey])
  @@index([runId, status])
}

/// A snapshot is a read-model of one scene for one visibility scope.  Public
/// and role-private snapshots deliberately occupy separate rows.
model SceneSnapshot {
  id                   String   @id @default(cuid())
  runId                String
  nodeId               String?
  roleId               String?
  scope                String   @default("public")
  stateJson            Json
  knownFactKeysJson    Json
  activeThreadKeysJson Json
  dedupeKey            String?  @unique
  createdAt            DateTime @default(now())

  run  StoryRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  node SceneNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  role StoryRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([runId, scope, createdAt])
  @@index([nodeId])
  @@index([roleId])
}

/// Unified narrative stream used by the chapter composer.  It supersedes
/// NarrativeSegment for new entries while preserving historic rows.
model NarrativeEntry {
  id                 String   @id @default(cuid())
  runId              String
  nodeId             String?
  resolutionId       String?
  roleId             String?
  entryType          String
  visibility         String   @default("public")
  content            String   @db.Text
  factKeysJson       Json
  threadKeysJson     Json
  sourceEventIdsJson Json
  dedupeKey          String?  @unique
  createdAt          DateTime @default(now())

  run        StoryRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  node       SceneNode?          @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  resolution DirectorResolution? @relation(fields: [resolutionId], references: [id], onDelete: SetNull)
  role       StoryRole?          @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([runId, visibility, createdAt])
  @@index([nodeId])
  @@index([roleId])
}

model Clue {
  id               String   @id @default(cuid())
  runId            String
  clueKey          String
  title            String
  description      String   @db.Text
  visibility       String   @default("public")
  ownerRoleId      String?
  discoveredNodeId String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  run       StoryRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  ownerRole StoryRole? @relation(fields: [ownerRoleId], references: [id], onDelete: SetNull)

  @@unique([runId, clueKey])
  @@index([runId, visibility, status])
  @@index([ownerRoleId])
}

model WorldStateSnapshot {
  id           String   @id @default(cuid())
  runId        String
  nodeId       String?
  chapterIndex Int
  stateJson    Json
  factsJson    Json
  createdAt    DateTime @default(now())

  run  StoryRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  node SceneNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([nodeId])
}

model Chapter {
  id              String   @id @default(cuid())
  runId           String
  chapterIndex    Int
  title           String
  content         String   @db.Text
  highlightsJson  Json
  keyChoicesJson  Json
  contributorJson Json
  nextHook        String?  @db.Text
  auditStatus     String   @default("ok")
  status          String   @default("generated")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run           StoryRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  notifications Notification[]
  aiTasks       AiTask[]
  shareTokens   ShareToken[]

  @@unique([runId, chapterIndex])
  @@index([runId, status])
  @@index([auditStatus])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  runId     String?
  nodeId    String?
  chapterId String?
  type      String
  title     String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  run     StoryRun?  @relation(fields: [runId], references: [id], onDelete: Cascade)
  node    SceneNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  chapter Chapter?   @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([runId])
}

model AiTask {
  id             String    @id @default(cuid())
  runId          String?
  eventId        String?
  nodeId         String?
  actionId       String?
  chapterId      String?
  taskType       String
  modelType      String
  promptVersion  String?
  status         String    @default("pending")
  inputJson      Json?
  resultJson     Json?
  outputJson     Json?
  rawResponse    String?   @db.Text
  normalizedJson Json?
  provider       String?
  modelName      String?
  tokenUsageJson Json?
  startedAt      DateTime?
  completedAt    DateTime?
  inputTokens    Int?
  outputTokens   Int?
  cost           Float?
  errorMessage   String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  run     StoryRun?     @relation(fields: [runId], references: [id], onDelete: Cascade)
  node    SceneNode?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  action  PlayerAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)
  chapter Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([taskType, status])
  @@index([runId])
  @@index([eventId])
  @@index([nodeId])
  @@index([chapterId])
}

/// Durable command queue for story resolution.  The unique node relation makes
/// command retries idempotent while a worker lease prevents concurrent consumers
/// from applying the same resolution twice.
model StoryTaskOutbox {
  id             String    @id @default(cuid())
  runId          String
  nodeId         String
  dedupeKey      String    @unique
  windowId       String?
  roleId         String?
  actionSlot     String?
  controlEpoch   Int?
  taskType       String
  status         String    @default("pending")
  outcome        String?
  inputRefId     String?
  checkpointKey  String?
  attempt        Int       @default(0)
  maxAttempts    Int       @default(3)
  nextRetryAt    DateTime  @default(now())
  leaseOwner     String?
  leaseExpiresAt DateTime?
  leaseVersion   Int       @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  resultJson     Json?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  run                 StoryRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  node                SceneNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  window              ActionWindow? @relation("StoryTaskOutboxWindow", fields: [windowId], references: [id], onDelete: SetNull)
  role                StoryRole?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  resolutionForWindow ActionWindow? @relation("ActionWindowResolutionTask")

  @@index([status, nextRetryAt])
  @@index([runId, createdAt])
  @@index([runId, taskType, status])
  @@index([nodeId])
  @@index([windowId, roleId, actionSlot])
  @@index([leaseOwner, leaseExpiresAt])
  @@index([leaseExpiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  targetType String
  targetId   String?
  content    String   @db.Text
  result     String
  riskType   String?
  provider   String   @default("mock")
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([result, createdAt])
}

model EventLog {
  id         String   @id @default(cuid())
  userId     String?
  runId      String?
  nodeId     String?
  actionId   String?
  eventName  String
  source     String?
  shareToken String?
  payload    Json?
  createdAt  DateTime @default(now())

  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  run    StoryRun?     @relation(fields: [runId], references: [id], onDelete: Cascade)
  node   SceneNode?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  action PlayerAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId])
  @@index([runId])
}

model ShareToken {
  id              String   @id @default(cuid())
  /// Legacy plaintext column. New code never writes it; the migration revokes
  /// and clears every existing value before secure public sharing is enabled.
  token           String?  @unique
  tokenHash       String?  @unique
  tokenPrefix     String?
  runId           String
  chapterId       String?
  shareUserId     String
  scene           String   @default("result")
  channel         String   @default("LINK")
  includeRoleName Boolean  @default(false)
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastAccessedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run       StoryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  shareUser User     @relation(fields: [shareUserId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([chapterId])
  @@index([shareUserId])
  @@index([tokenHash, expiresAt, revokedAt])
}

enum CreditGrantKind {
  PURCHASED
  BONUS
}

enum CreditGrantSource {
  SIGNUP
  REFERRAL
  PURCHASE
  SYSTEM_REFUND
  ADMIN
}

enum CreditLedgerReason {
  SIGNUP_BONUS
  REFERRAL_REWARD
  PURCHASE
  WORLD_UNLOCK
  SYSTEM_REFUND
  BONUS_EXPIRED
  PURCHASE_REFUND
  DISPUTE
  ADMIN_ADJUSTMENT
}

enum CreemPurchaseStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  FAILED
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  PROVIDER_ACTION_REQUIRED
  SUBMITTED
  COMPLETED
  REJECTED
  FAILED
}

enum WebhookProcessStatus {
  PROCESSED
  IGNORED
}

enum ReferralStatus {
  REGISTERED
  QUALIFIED
  REWARDED
  QUALIFIED_NO_REWARD
}

enum ReferralChannel {
  UNKNOWN
  LINK
  X
  FACEBOOK
  WHATSAPP
  TELEGRAM
  DISCORD
  NATIVE
}

enum WorldUnlockStatus {
  COMMITTED
  REFUNDED
}

model CreditWallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  purchasedBalance Int      @default(0)
  bonusBalance     Int      @default(0)
  debtBalance      Int      @default(0)
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model CreditGrant {
  id              String            @id @default(cuid())
  userId          String
  kind            CreditGrantKind
  source          CreditGrantSource
  originalAmount  Int
  remainingAmount Int
  expiresAt       DateTime?
  idempotencyKey  String            @unique
  externalRef     String?
  metadataJson    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  allocations CreditSpendAllocation[]

  @@index([userId, kind, expiresAt])
  @@index([externalRef])
}

model CreditLedger {
  id             String             @id @default(cuid())
  userId         String
  reason         CreditLedgerReason
  purchasedDelta Int                @default(0)
  bonusDelta     Int                @default(0)
  debtDelta      Int                @default(0)
  idempotencyKey String             @unique
  externalRef    String?
  metadataJson   Json?
  createdAt      DateTime           @default(now())

  allocations CreditSpendAllocation[]

  @@index([userId, createdAt])
  @@index([externalRef])
}

model CreditSpendAllocation {
  id        String   @id @default(cuid())
  ledgerId  String
  grantId   String
  amount    Int
  createdAt DateTime @default(now())

  ledger CreditLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  grant  CreditGrant  @relation(fields: [grantId], references: [id], onDelete: Restrict)

  @@unique([ledgerId, grantId])
  @@index([grantId])
}

model CreemPurchase {
  id                  String              @id @default(cuid())
  userId              String
  packKey             String
  creemProductId      String
  credits             Int
  expectedAmountCents Int
  expectedCurrency    String              @default("USD")
  // The database default keeps rolling deploys compatible with API instances
  // from before this field was introduced. Current code still supplies a
  // human-friendly value explicitly.
  orderDisplayCode    String              @unique @default(dbgenerated("('MW-'::text || upper(\"left\"(replace((gen_random_uuid())::text, '-'::text, ''::text), 12)))"))
  status              CreemPurchaseStatus @default(PENDING)
  checkoutId          String?             @unique
  orderId             String?             @unique
  transactionId       String?             @unique
  customerId          String?
  customerEmail       String?
  paidAmountCents     Int?
  paidCurrency        String?
  checkoutContext     Json?
  rawJson             Json?
  createdAt           DateTime            @default(now())
  paidAt              DateTime?
  refundedAt          DateTime?
  updatedAt           DateTime            @updatedAt

  refundRequest RefundRequest?

  @@index([userId, createdAt])
  @@index([creemProductId])
}

model RefundRequest {
  id                   String              @id @default(cuid())
  purchaseId           String              @unique
  userId               String
  status               RefundRequestStatus @default(PENDING)
  reason               String
  message              String?             @db.Text
  requestedAmountCents Int
  reviewerUserId       String?
  adminNote            String?             @db.Text
  providerRefundId     String?
  providerStatus       String?
  providerResponseJson Json?
  failureCode          String?
  failureMessage       String?             @db.Text
  requestedAt          DateTime            @default(now())
  reviewedAt           DateTime?
  submittedAt          DateTime?
  completedAt          DateTime?
  updatedAt            DateTime            @updatedAt

  purchase  CreemPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  requester User          @relation("RefundRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer  User?         @relation("RefundReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([userId, requestedAt])
  @@index([status, requestedAt])
  @@index([reviewerUserId])
}

model PaymentWebhookEvent {
  eventId     String               @id
  eventType   String
  status      WebhookProcessStatus
  payloadJson Json
  createdAt   DateTime             @default(now())
  processedAt DateTime             @default(now())
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())

  referrals Referral[]
}

model Referral {
  id              String          @id @default(cuid())
  referralCodeId  String
  inviterUserId   String
  referredUserId  String          @unique
  channel         ReferralChannel @default(UNKNOWN)
  status          ReferralStatus  @default(REGISTERED)
  qualifiedRunId  String?
  rewardLedgerId  String?
  rejectionReason String?
  registeredAt    DateTime        @default(now())
  qualifiedAt     DateTime?
  rewardedAt      DateTime?
  updatedAt       DateTime        @updatedAt

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Restrict)

  @@index([inviterUserId, status])
  @@index([referralCodeId])
}

model ReferralShareEvent {
  id        String          @id @default(cuid())
  userId    String
  channel   ReferralChannel
  runId     String?
  createdAt DateTime        @default(now())

  @@index([userId, createdAt])
}

model WorldUnlock {
  id             String            @id @default(cuid())
  runId          String            @unique
  templateKey    String
  paidByUserId   String
  creditsCharged Int
  debitLedgerId  String            @unique
  status         WorldUnlockStatus @default(COMMITTED)
  createdAt      DateTime          @default(now())
  refundedAt     DateTime?

  run StoryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([paidByUserId, createdAt])
}
