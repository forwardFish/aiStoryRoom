{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "apps/web/dist-vercel",
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": false },
    { "source": "/credits.html", "destination": "/credits", "permanent": false },
    { "source": "/credits-success.html", "destination": "/credits/status", "permanent": false },
    { "source": "/join.html", "destination": "/join", "permanent": false },
    { "source": "/room-game", "destination": "/game", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://accounts.google.com/gsi/client; style-src 'self' 'unsafe-inline' https://accounts.google.com/gsi/style; img-src 'self' data: blob: https://*.googleusercontent.com; connect-src 'self' https://accounts.google.com/gsi/; frame-src https://accounts.google.com/gsi/ https://accounts.google.com/; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy?path=:path*" },
    { "source": "/", "destination": "/home.html" },
    { "source": "/home", "destination": "/home.html" },
    { "source": "/privacy", "destination": "/legal.html" },
    { "source": "/terms", "destination": "/legal.html" },
    { "source": "/refund", "destination": "/legal.html" },
    { "source": "/role-select", "destination": "/role-select.html" },
    { "source": "/game", "destination": "/index.html" },
    { "source": "/trio", "destination": "/trio.html" },
    { "source": "/auth", "destination": "/platform.html" },
    { "source": "/account", "destination": "/platform.html" },
    { "source": "/admin/refunds", "destination": "/platform.html" },
    { "source": "/shared/result", "destination": "/platform.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/join", "destination": "/platform.html" },
    { "source": "/worlds", "destination": "/worlds.html" },
    { "source": "/worlds/:path*", "destination": "/platform.html" },
    { "source": "/rooms", "destination": "/platform.html" },
    { "source": "/rooms/:path*", "destination": "/platform.html" },
    { "source": "/game/result", "destination": "/platform.html" },
    { "source": "/credits", "destination": "/credits.html" },
    { "source": "/credits/status", "destination": "/credits-status.html" },
    { "source": "/credits/cancel", "destination": "/credits-status.html" },
    { "source": "/credits/failed", "destination": "/credits-status.html" }
  ]
}
