NODE_ENV=development
AUTH_COOKIE_SECURE=
API_PORT=3001
MINIPROGRAM_API_BASE_URL=http://localhost:3001

# Production deployment target: Supabase PostgreSQL (use the pooler/direct URL
# from the Supabase dashboard; keep secrets in .env or the deployment secret store).
# Local Docker is optional and remains the default fallback when DATABASE_URL is absent.
DATABASE_URL=""
RESTORE_DATABASE_URL=""
DATABASE_TARGET=external
SUPABASE_PROJECT_REF=
SUPABASE_PITR_ENABLED=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET="local_dev_secret_change_me"
MOCK_WECHAT_OPENID_PREFIX="mock_openid_"

AI_PROVIDER=mock
AI_MODEL=mock-director-v1
AI_TIMEOUT_MS=30000
AUDIT_PROVIDER=mock

# Causal Web MVP: the rule engine remains authoritative; DeepSeek may only
# polish player-visible narration and automatically falls back to rules.
MVP_STORY_DATA_DIR=.runtime/mvp-story-runs
MVP_STORY_STORAGE=prisma
AI_CAUSAL_PROVIDER=rules
AI_CAUSAL_TIMEOUT_MS=15000
AI_CAUSAL_MAX_ATTEMPTS=2
# Per-run AI hard limits. Reaching a configured limit switches later narration
# to deterministic rules without changing any already committed causal state.
AI_RUN_MAX_CALLS=55
AI_RUN_MAX_TOTAL_TOKENS=260000
AI_RUN_COST_LIMIT_MINOR=
AI_DECISION_MAX_INPUT_TOKENS=6000
AI_DECISION_MAX_OUTPUT_TOKENS=1800
AI_INPUT_PRICE_PER_MILLION_MINOR=0
AI_OUTPUT_PRICE_PER_MILLION_MINOR=0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ENABLE_MOCK_LOGIN=true
ENABLE_MOCK_AI=true
ENABLE_MOCK_AUDIT=true
ENABLE_BULLMQ=false

# Many Worlds World Credits / Creem Test Mode
PUBLIC_WEB_URL=http://localhost:5200
PUBLIC_API_URL=http://localhost:3001
CREEM_MODE=test
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_300_ID=prod_xkzSkuNeiQuP1QVNV6NbL
CREEM_PRODUCT_650_ID=prod_43UaxI9MUzfbPcGZtBbvQD
CREEM_MOCK_MODE=false
# Comma-separated login emails allowed to review refund requests. Empty means
# every admin refund endpoint fails closed.
ADMIN_EMAILS=
REFUND_REQUEST_WINDOW_DAYS=14
# Keep empty until Creem supplies a documented, account-approved server refund
# endpoint. It must be a relative /v1/.../{transactionId} path; arbitrary hosts
# are rejected. The public Creem API does not currently publish this contract.
CREEM_REFUND_API_PATH=
# Authentication: keep all secrets in the deployment environment, never in Git.
AUTH_TOKEN_SECRET=
EMAIL_PROVIDER=file-sink
AUTH_MAIL_SINK_FILE=.auth-mail-sink.ndjson
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_VERIFY_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=15
GOOGLE_AUTH_ENABLED=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_LOGIN_CHALLENGE_TTL_SECONDS=300
# Vercel build variable only; it is intentionally public and must be the same
# Web Client ID as GOOGLE_WEB_CLIENT_ID. Do not add a Google client secret.
PUBLIC_GOOGLE_WEB_CLIENT_ID=
CREDIT_SIGNUP_BONUS=50
CREDIT_REFERRAL_REWARD=25
CREDIT_REFERRAL_MAX_REWARDS=2
CREDIT_BONUS_TTL_DAYS=90
CREDIT_STANDARD_WORLD_COST=100
CREDIT_FREE_DECISION_LIMIT=3
REFERRAL_BASE_URL=http://localhost:5200/join.html
