NODE_ENV=development
API_PORT=3001
MINIPROGRAM_API_BASE_URL=http://localhost:3001

DATABASE_URL="postgresql://ai_story:ai_story_pwd@localhost:5432/ai_story_run?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET="local_dev_secret_change_me"
MOCK_WECHAT_OPENID_PREFIX="mock_openid_"

AI_PROVIDER=mock
AI_MODEL=mock-director-v1
AI_TIMEOUT_MS=30000
AUDIT_PROVIDER=mock

# Causal Web MVP: the rule engine remains authoritative; DeepSeek may only
# polish player-visible narration and automatically falls back to rules.
MVP_STORY_DATA_DIR=.runtime/mvp-story-runs
AI_CAUSAL_PROVIDER=rules
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

ENABLE_MOCK_LOGIN=true
ENABLE_MOCK_AI=true
ENABLE_MOCK_AUDIT=true
ENABLE_BULLMQ=false
