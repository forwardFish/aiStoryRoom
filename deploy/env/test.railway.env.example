# Our Many Worlds - Railway TEST environment
# Copy to test.railway.env.local, fill every <...> value, then paste the
# completed file into the Railway TEST project's Shared Variables / Raw Editor.
# Never commit the .local copy.

# Runtime and database: use the TEST Supabase project only.
NODE_ENV=development
DATABASE_URL=<SUPABASE_TEST_SESSION_POOLER_URL>
MVP_STORY_STORAGE=prisma

# Public origins
PUBLIC_WEB_URL=https://test.ourmanyworlds.com
PAYMENT_RETURN_ORIGIN=https://test.ourmanyworlds.com
REFERRAL_BASE_URL=https://test.ourmanyworlds.com/join
CORS_ALLOWED_ORIGINS=https://test.ourmanyworlds.com

# Authentication
AUTH_TOKEN_SECRET=<TEST_RANDOM_SECRET_AT_LEAST_64_BYTES>
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_DAYS=30
GOOGLE_AUTH_ENABLED=true
GOOGLE_WEB_CLIENT_ID=<GOOGLE_TEST_WEB_CLIENT_ID>
GOOGLE_LOGIN_CHALLENGE_TTL_SECONDS=300

# Transactional email: use a TEST-only Resend key/sending domain.
EMAIL_PROVIDER=resend
RESEND_API_KEY=<RESEND_TEST_SENDING_KEY>
EMAIL_FROM="Our Many Worlds Test <noreply@test.ourmanyworlds.com>"
EMAIL_REPLY_TO=<TEST_SUPPORT_EMAIL>
EMAIL_VERIFY_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=15

# Creem sandbox
CREEM_MODE=test
CREEM_MOCK_MODE=false
CREEM_API_KEY=<CREEM_TEST_API_KEY>
CREEM_WEBHOOK_SECRET=<CREEM_TEST_WEBHOOK_SECRET>
CREEM_PRODUCT_300_ID=<CREEM_TEST_PRODUCT_300_ID>
CREEM_PRODUCT_650_ID=<CREEM_TEST_PRODUCT_650_ID>
CREEM_REFUND_API_PATH=
ADMIN_EMAILS=<TEST_ADMIN_EMAILS_COMMA_SEPARATED>
REFUND_REQUEST_WINDOW_DAYS=14

# Credits and test-only controls
ALLOW_TEST_CREDIT_GRANT=true
CREDIT_SIGNUP_BONUS=50
CREDIT_REFERRAL_REWARD=25
CREDIT_REFERRAL_MAX_REWARDS=2
CREDIT_BONUS_TTL_DAYS=90
CREDIT_STANDARD_WORLD_COST=100
CREDIT_FREE_DECISION_LIMIT=3

# AI provider: use a TEST-only key and budget.
AI_CAUSAL_PROVIDER=deepseek
AI_CAUSAL_TIMEOUT_MS=15000
AI_CAUSAL_MAX_ATTEMPTS=2
AI_RUN_MAX_CALLS=55
AI_RUN_MAX_TOTAL_TOKENS=260000
AI_RUN_COST_LIMIT_MINOR=<TEST_RUN_COST_LIMIT_MINOR>
AI_DECISION_MAX_INPUT_TOKENS=6000
AI_DECISION_MAX_OUTPUT_TOKENS=1800
AI_INPUT_PRICE_PER_MILLION_MINOR=<DEEPSEEK_INPUT_PRICE_MINOR>
AI_OUTPUT_PRICE_PER_MILLION_MINOR=<DEEPSEEK_OUTPUT_PRICE_MINOR>
DEEPSEEK_API_KEY=<DEEPSEEK_TEST_API_KEY>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Continuous multiplayer and worker topology
MULTIPLAYER_CONTINUOUS_STRATEGY_ENABLED=true
CONTINUOUS_TIMING_PROFILE=realtime
ROLE_AGENT_PROVIDER=deepseek
ROLE_AGENT_MODEL=deepseek-chat
ROLE_AGENT_TIMEOUT_MS=4500
STORY_WORKER_EMBEDDED=false
STORY_TASK_LEASE_MS=60000

# API protection. These limits are per API process in the current codebase.
API_WRITE_RATE_LIMIT_PER_MINUTE=120
HEARTBEAT_SESSION_RATE_LIMIT_PER_MINUTE=90
HEARTBEAT_USER_RATE_LIMIT_PER_MINUTE=240
HEARTBEAT_IP_RATE_LIMIT_PER_MINUTE=600
HEARTBEAT_MIN_INTERVAL_MS=500
HEARTBEAT_STALE_MS=15000
