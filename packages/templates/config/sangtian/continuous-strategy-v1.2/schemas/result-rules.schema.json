{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ourmanyworlds.com/schemas/continuous-strategy/result-rules-v1.json",
  "title": "Continuous Strategy Result Rules V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contentVersion",
    "publicStageRules",
    "personalStageRules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "continuous_strategy_result_rules_v1"
    },
    "contentVersion": {
      "const": "sangtian_v1_2"
    },
    "publicStageRules": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/publicRule"
      }
    },
    "personalStageRules": {
      "type": "array",
      "minItems": 21,
      "maxItems": 21,
      "items": {
        "$ref": "#/$defs/personalRule"
      }
    }
  },
  "$defs": {
    "publicRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleKey",
        "stageKey",
        "candidateFactKeys",
        "outcomeStateKey",
        "summary"
      ],
      "properties": {
        "ruleKey": {
          "type": "string"
        },
        "stageKey": {
          "type": "string"
        },
        "candidateFactKeys": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "outcomeStateKey": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "personalRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleKey",
        "stageKey",
        "roleKey",
        "candidateFactKeys",
        "summary"
      ],
      "properties": {
        "ruleKey": {
          "type": "string"
        },
        "stageKey": {
          "type": "string"
        },
        "roleKey": {
          "type": "string"
        },
        "candidateFactKeys": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
