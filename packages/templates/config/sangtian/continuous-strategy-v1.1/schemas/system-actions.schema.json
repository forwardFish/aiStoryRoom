{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ourmanyworlds.com/schemas/continuous-strategy/system-actions-v1.json",
  "title": "Continuous Strategy System Actions V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contentVersion", "systemActions"],
  "properties": {
    "schemaVersion": { "const": "continuous_strategy_system_actions_v1" },
    "contentVersion": { "const": "sangtian_v1_1" },
    "systemActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["systemActionKey", "stageKey", "roleKey", "inputStateKeys", "factKeys", "observableTraceKeys", "visiblePressure", "claimable", "controllerMode", "assetMutations", "nextStateKey"],
        "properties": {
          "systemActionKey": { "type": "string" }, "stageKey": { "type": "string" }, "roleKey": { "type": "string" },
          "inputStateKeys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "factKeys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "observableTraceKeys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "visiblePressure": { "type": "string", "minLength": 1 },
          "claimable": { "const": false },
          "controllerMode": { "const": "SYSTEM" },
          "assetMutations": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["assetKey", "mutationType", "delta", "toRoleKey"],
              "properties": { "assetKey": { "type": "string" }, "mutationType": { "type": "string" }, "delta": { "type": "integer" }, "toRoleKey": { "type": ["string", "null"] } }
            }
          },
          "nextStateKey": { "type": "string" }
        }
      }
    }
  }
}
