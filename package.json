{
  "name": "ai-story-room",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @apps/api dev",
    "dev:preview-api": "pnpm dev:api",
    "dev:legacy-preview-api": "tsx scripts/preview-api.ts",
    "dev:web": "pnpm --filter @apps/web dev",
    "dev:miniprogram": "pnpm --filter @apps/miniprogram dev:weapp",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "test:api": "pnpm --filter @apps/api test",
    "test:causal:web": "pnpm --filter @apps/web test",
    "test:causal": "pnpm test:api && pnpm test:causal:web",
    "test:story:e2e": "tsx scripts/e2e/story-multirole.ts",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
