{
  "name": "ai-story-room",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm build:api",
    "build:api": "pnpm db:generate && pnpm --filter @apps/api build",
    "dev:api": "pnpm --filter @apps/api dev",
    "dev:api:test": "pnpm --filter @apps/api run dev:test",
    "dev:api:prd": "pnpm --filter @apps/api run dev:prd",
    "dev:preview-api": "pnpm dev:api",
    "dev:legacy-preview-api": "tsx scripts/preview-api.ts",
    "dev:web": "pnpm --filter @apps/web dev",
    "dev:web:test": "node --env-file=.env.test apps/web/src/server.mjs",
    "dev:web:prd": "node --env-file=.env.prd apps/web/src/server.mjs",
    "dev:story-worker": "pnpm --filter @apps/api run worker",
    "worker:test": "pnpm --filter @apps/api run worker:test",
    "worker:prd": "pnpm --filter @apps/api run worker:prd",
    "env:check:test": "node scripts/deploy/prepare-env-files.mjs test --check",
    "env:check:prd": "node scripts/deploy/prepare-env-files.mjs prd --check",
    "env:merge-current-test": "node scripts/deploy/merge-current-test-env.mjs",
    "env:export:test": "node scripts/deploy/prepare-env-files.mjs test",
    "env:export:prd": "node scripts/deploy/prepare-env-files.mjs prd",
    "dev:miniprogram": "pnpm --filter @apps/miniprogram dev:weapp",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "build:vercel": "node scripts/deploy/prepare-vercel-web-assets.mjs && pnpm --filter @apps/web build",
    "lint:config": "tsx scripts/config/lint-sangtian-config.ts",
    "test:config": "pnpm lint:config",
    "test:api": "pnpm --filter @apps/api test",
    "test:causal:web": "pnpm --filter @apps/web test",
    "test:causal": "pnpm test:api && pnpm test:causal:web",
    "test:story:e2e": "tsx scripts/e2e/story-multirole.ts",
    "test:story:triad": "tsx scripts/e2e/three-player-seven-round.ts",
    "test:story:async-v2": "tsx --env-file=.env.test scripts/e2e/continuous-story-v2-async.ts",
    "test:story:browser-v2": "node scripts/acceptance/continuous-story-v2-browser.mjs",
    "test:story:browser-v2-full": "node scripts/acceptance/continuous-story-v2-visible-journeys.mjs",
    "test:caesar-solo-seven": "tsx scripts/e2e/caesar-solo-seven-smoke.ts",
    "test:many-worlds-pages": "node scripts/e2e/many-worlds-v13-page-interactions.mjs",
    "test:many-worlds-room-smoke": "node scripts/e2e/many-worlds-v13-browser-room-smoke.mjs",
    "test:many-worlds-visual": "node scripts/acceptance/capture-many-worlds-v13-visual.mjs && python scripts/acceptance/compare-many-worlds-v13-visual.py",
    "test:story:v4-db": "tsx scripts/e2e/v4-database-smoke.ts",
    "test:world-credits": "tsx scripts/e2e/world-credits-local.ts",
    "test:world-credits:consumption-db": "tsx --env-file=.env.test --tsconfig apps/api/tsconfig.json scripts/e2e/world-credits-consumption-db.ts",
    "test:api-contract": "tsx --tsconfig apps/api/tsconfig.json scripts/e2e/v4-api-contract-audit.ts",
    "test:story:three-four": "tsx scripts/e2e/three-player-four-round.ts",
    "test:maneuver": "tsx scripts/e2e/mvp-acceptance-matrix.ts maneuver",
    "test:paths": "tsx scripts/e2e/mvp-acceptance-matrix.ts paths",
    "test:security-projection": "tsx scripts/e2e/mvp-acceptance-matrix.ts security",
    "test:concurrency": "tsx scripts/e2e/mvp-acceptance-matrix.ts concurrency",
    "test:ai-failure": "tsx scripts/e2e/mvp-acceptance-matrix.ts ai-failure",
    "test:provider-retry": "tsx scripts/e2e/provider-retry-contract.ts",
    "test:ai-budget": "tsx scripts/e2e/ai-budget-contract.ts",
    "test:continuous": "tsx scripts/e2e/mvp-acceptance-matrix.ts continuous",
    "test:continuous-mp:fault": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\acceptance\\run-continuous-fault-recovery.ps1",
    "test:storage-recovery": "tsx scripts/e2e/storage-failure-recovery.ts",
    "test:ai-live-v4": "tsx scripts/e2e/v4-deepseek-live-smoke.ts",
    "test:simulated-player": "node scripts/e2e/simulated-player-browser.mjs",
    "test:ops-contract": "node scripts/ops/ops-contract.mjs",
    "test:deploy-config": "node scripts/deploy/railway-config.test.mjs",
    "test:db-ops": "powershell -ExecutionPolicy Bypass -File .\\scripts\\acceptance\\run-db-ops-acceptance.ps1",
    "test:db-ops-local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\acceptance\\run-local-postgres-ops.ps1",
    "test:acceptance": "pnpm test:config && pnpm test:causal && pnpm test:api-contract && pnpm test:maneuver && pnpm test:paths && pnpm test:security-projection && pnpm test:concurrency && pnpm test:ai-failure && pnpm test:provider-retry && pnpm test:ai-budget && pnpm test:continuous && pnpm test:storage-recovery && pnpm test:ops-contract",
    "ops:backup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ops\\backup-postgres.ps1",
    "ops:restore-smoke": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ops\\restore-smoke.ps1",
    "ops:wal-check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\ops\\check-wal-archive.ps1",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
